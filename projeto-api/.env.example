# Ambiente
ENV=dev
LOG_LEVEL=INFO

# Banco (asyncpg para app; psycopg2 para Alembic via DATABASE_URL_SYNC)
DATABASE_URL=postgresql+asyncpg://dashboard:dashboard@localhost:5433/dashboard_fg
DATABASE_URL_SYNC=postgresql+psycopg2://dashboard:dashboard@localhost:5433/dashboard_fg

# OAuth Google
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
ALLOWED_DOMAIN=furtadoguerini.com.br
SESSION_SECRET=mudar-em-producao-minimo-32-chars

# DataJuri
DATAJURI_BASE_URL=https://api.datajuri.com.br
DATAJURI_TENANT=furtadoguerini
DATAJURI_USER=
DATAJURI_PASSWORD=
DATAJURI_TOKEN_ENDPOINT=/oauth/token
DATAJURI_PAGE_SIZE=1000
DATAJURI_DATA_INICIO=2025-09-01

# CORS (dev)
CORS_ORIGINS=http://localhost:5173
